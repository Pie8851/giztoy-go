{
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["react", "react-dom"]
  },
  "include": [
    "global.d.ts",
    "admin/**/*.ts",
    "admin/**/*.tsx",
    "play/**/*.ts",
    "play/**/*.tsx",
    "../../js/packages/**/*.ts"
  ]
}
