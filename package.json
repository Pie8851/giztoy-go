{
  "name": "gizclaw-go",
  "private": true,
  "workspaces": [
    "apps/wails/frontend",
    "sdk/js",
    "sdk/js/gizclaw"
  ],
  "devDependencies": {
    "oxlint": "1.75.0",
    "prettier": "3.9.6",
    "typescript": "6.0.3"
  },
  "scripts": {
    "quality:typescript": "tsc --noEmit -p apps/wails/frontend/tsconfig.json && tsc --noEmit -p sdk/js/gizclaw/tsconfig.json",
    "quality:lint": "oxlint --deny-warnings --ignore-path .prettierignore apps/wails/frontend sdk/js tests/gizclaw-e2e/js",
    "quality:format": "prettier --check apps/wails/frontend sdk/js tests/gizclaw-e2e/js"
  }
}
