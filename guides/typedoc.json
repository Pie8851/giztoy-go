{
  "$schema": "https://typedoc.org/schema.json",
  "tsconfig": "tsconfig.typedoc.json",
  "entryPoints": ["../sdk/js/gizclaw/**/*.ts"],
  "entryPointStrategy": "expand",
  "exclude": ["../sdk/js/gizclaw/**/*.test.ts"],
  "out": "references/typescript",
  "name": "GizClaw TypeScript SDK",
  "readme": "none",
  "externalSymbolLinkMappings": {
    "typescript": {
      "Body": "https://developer.mozilla.org/docs/Web/API/Request/body",
      "JSON.stringify": "https://developer.mozilla.org/docs/Web/JavaScript/Reference/Global_Objects/JSON/stringify"
    }
  }
}
