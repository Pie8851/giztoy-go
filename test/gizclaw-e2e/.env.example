# Copy this file to test/gizclaw-e2e/.env before running local e2e setup.
# The local .env file must stay uncommitted.
#
# Keep this file limited to values that cannot be committed as fixtures:
# provider credentials and provider tokens.

# ---------------------------------------------------------------------------
# Volc/Doubao provider credentials
# ---------------------------------------------------------------------------

GIZCLAW_E2E_VOLC_APP_ID=
GIZCLAW_E2E_VOLC_ARK_API_KEY=
GIZCLAW_E2E_VOLC_ACCESS_KEY_ID=
GIZCLAW_E2E_VOLC_SECRET_ACCESS_KEY=
GIZCLAW_E2E_VOLC_WEBSEARCH_API_KEY=
GIZCLAW_E2E_VOLC_TOKEN=

# ---------------------------------------------------------------------------
# Optional OpenAI-compatible credential
# ---------------------------------------------------------------------------

# This is optional unless running OpenAI-compatible HTTP coverage.
GIZCLAW_E2E_OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Optional context role overrides
# ---------------------------------------------------------------------------
#
# Leave these empty for the committed local testdata contexts. Set them only
# when running e2e against existing local or remote dev contexts.

# Used by setup/reset_data.sh for admin resource initialization.
GIZCLAW_E2E_ADMIN_SETUP_CONFIG_HOME=
GIZCLAW_E2E_ADMIN_SETUP_CONTEXT=

# Target role for cmd/admin CLI e2e stories when they opt into external contexts.
GIZCLAW_E2E_ADMIN_CLI_CONFIG_HOME=
GIZCLAW_E2E_ADMIN_CLI_CONTEXT=

# Used by ordinary client/workspace/rpc e2e cases.
GIZCLAW_E2E_CLIENT_CONFIG_HOME=
GIZCLAW_E2E_CLIENT_CONTEXT=

# Used by social e2e role A.
GIZCLAW_E2E_SOCIAL_PERSON_A_CONFIG_HOME=
GIZCLAW_E2E_SOCIAL_PERSON_A_CONTEXT=

# Used by social e2e role B.
GIZCLAW_E2E_SOCIAL_PERSON_B_CONFIG_HOME=
GIZCLAW_E2E_SOCIAL_PERSON_B_CONTEXT=

# Used to launch the Play UI surface.
GIZCLAW_E2E_PLAY_UI_CONFIG_HOME=
GIZCLAW_E2E_PLAY_UI_CONTEXT=

# Target role for cmd/play CLI e2e stories when they opt into external contexts.
GIZCLAW_E2E_PLAY_CLI_CONFIG_HOME=
GIZCLAW_E2E_PLAY_CLI_CONTEXT=
