listen: "__LISTEN_ADDR__"
cipher-mode: "__CIPHER_MODE__"
__ADMIN_PUBLIC_KEY_LINE__storage:
  memory:
    kind: keyvalue
    memory: {}
  local-files:
    kind: filesystem
    fs:
      dir: .
  agenthost-files:
    kind: objectstore
    fs:
      dir: data/agenthost
  acl-db:
    kind: sql
    sqlite:
      dir: data/acl.sqlite
  history-db:
    kind: sql
    sqlite:
      dir: data/history.sqlite
stores:
  peers:
    kind: keyvalue
    storage: memory
    prefix: peers
  credentials:
    kind: keyvalue
    storage: memory
    prefix: credentials
  firmwares:
    kind: keyvalue
    storage: memory
    prefix: firmwares
  agenthost:
    kind: objectstore
    storage: agenthost-files
  minimax-tenants:
    kind: keyvalue
    storage: memory
    prefix: minimax-tenants
  voices:
    kind: keyvalue
    storage: memory
    prefix: voices
  workspaces:
    kind: keyvalue
    storage: memory
    prefix: workspaces
  workflows:
    kind: keyvalue
    storage: memory
    prefix: workflows
  acl:
    kind: sql
    storage: acl-db
  history:
    kind: sql
    storage: history-db
peers:
  store: peers
credentials:
  store: credentials
firmwares:
  store: firmwares
minimax:
  tenants-store: minimax-tenants
  voices-store: voices
  credentials-store: credentials
workspaces:
  store: workspaces
workflows:
  store: workflows
acl:
  store: acl
history:
  store: history
