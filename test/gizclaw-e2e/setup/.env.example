GIZCLAW_E2E_ADMIN_PUBLIC_KEY=
GIZCLAW_E2E_CLIENT_PUBLIC_KEY=

GIZCLAW_E2E_ADMIN_CONTEXT=e2e-admin
GIZCLAW_E2E_CLIENT_CONTEXT=e2e-client
GIZCLAW_E2E_SERVER_ADDR=127.0.0.1:9820

# Used by workspace e2e when it dials the server directly instead of using a
# saved CLI context. This must match GIZCLAW_E2E_CLIENT_PUBLIC_KEY.
GIZCLAW_WORKSPACE_CLIENT_PRIVATE_KEY=

GIZCLAW_E2E_OPENAI_API_KEY=
GIZCLAW_E2E_OPENAI_BASE_URL=
GIZCLAW_E2E_OPENAI_UPSTREAM_MODEL=

GIZCLAW_E2E_VOLC_APP_ID=
GIZCLAW_E2E_VOLC_ARK_API_KEY=
GIZCLAW_E2E_VOLC_TOKEN=
GIZCLAW_E2E_VOLC_VOICE_ID=
GIZCLAW_E2E_VOICE_RESOURCE=volc-tenant:e2e-volc-tenant:<voice-id>

# Optional resource naming overrides.
GIZCLAW_E2E_OPENAI_CREDENTIAL=e2e-openai-credential
GIZCLAW_E2E_OPENAI_TENANT=e2e-openai-tenant
GIZCLAW_E2E_VOLC_CREDENTIAL=e2e-volc-credential
GIZCLAW_E2E_VOLC_TENANT=e2e-volc-tenant
GIZCLAW_E2E_CHAT_MODEL=e2e-chat
GIZCLAW_E2E_TTS_MODEL=e2e-tts
GIZCLAW_E2E_ASR_MODEL=e2e-asr
GIZCLAW_E2E_REALTIME_MODEL=e2e-realtime
GIZCLAW_E2E_ACL_VIEW=e2e-client
GIZCLAW_E2E_WORKSPACE=doubao-realtime
GIZCLAW_E2E_WORKFLOW=e2e-doubao-realtime
