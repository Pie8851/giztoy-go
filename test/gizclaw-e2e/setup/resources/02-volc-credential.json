{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "Credential",
  "metadata": {
    "name": "${GIZCLAW_E2E_VOLC_CREDENTIAL:-e2e-volc-credential}"
  },
  "spec": {
    "provider": "volc",
    "description": "E2E Volc/Doubao credential",
    "body": {
      "app_id": "${GIZCLAW_E2E_VOLC_APP_ID}",
      "api_key": "${GIZCLAW_E2E_VOLC_ARK_API_KEY}",
      "token": "${GIZCLAW_E2E_VOLC_TOKEN}"
    }
  }
}
