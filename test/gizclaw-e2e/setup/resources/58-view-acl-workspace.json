{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "ACLPolicyBinding",
  "metadata": {
    "name": "view-${GIZCLAW_E2E_ACL_VIEW:-e2e-client}-workspace-collection"
  },
  "spec": {
    "subject": {
      "kind": "view",
      "id": "${GIZCLAW_E2E_ACL_VIEW:-e2e-client}"
    },
    "resource": {
      "kind": "workspace",
      "id": "__collection__"
    },
    "role": "${GIZCLAW_E2E_CLIENT_ROLE:-e2e-client}"
  }
}
