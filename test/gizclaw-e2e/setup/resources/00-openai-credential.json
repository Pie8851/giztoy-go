{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "Credential",
  "metadata": {
    "name": "${GIZCLAW_E2E_OPENAI_CREDENTIAL:-e2e-openai-credential}"
  },
  "spec": {
    "provider": "openai",
    "description": "E2E OpenAI-compatible credential",
    "body": {
      "api_key": "${GIZCLAW_E2E_OPENAI_API_KEY}"
    }
  }
}
