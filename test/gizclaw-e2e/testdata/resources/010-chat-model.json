{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "Model",
  "metadata": {
    "name": "e2e-chat"
  },
  "spec": {
    "kind": "llm",
    "source": "manual",
    "provider": {
      "kind": "openai-tenant",
      "name": "e2e-openai-tenant"
    },
    "name": "E2E Chat",
    "description": "E2E OpenAI-compatible chat model",
    "capabilities": {
      "json_output": true,
      "system_role": true,
      "temperature": true,
      "text_only": true,
      "tool_calls": true
    },
    "provider_data": {
      "upstream_model": "gpt-4o-mini",
      "support_json_output": true,
      "support_text_only": true,
      "support_tool_calls": true,
      "use_system_role": true
    }
  }
}
