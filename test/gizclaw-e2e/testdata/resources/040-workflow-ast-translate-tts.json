{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "Workflow",
  "metadata": {
    "name": "e2e-ast-translate-tts",
    "description": "Workspace e2e AST text translation with external GizClaw TTS voice"
  },
  "spec": {
    "driver": "ast-translate",
    "ast_translate": {
      "translation_model": "e2e-ast-translate",
      "auth_mode": "v2",
      "mode": "s2t",
      "voice": {
        "tts_voice": "volc-tenant:e2e-volc-tenant:zh_female_vv_mars_bigtts"
      },
      "resource_id": "volc.service_type.10053",
      "denoise": false
    }
  }
}
