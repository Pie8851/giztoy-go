{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "Workflow",
  "metadata": {
    "name": "e2e-doubao-realtime",
    "description": "Workspace e2e Doubao realtime workflow"
  },
  "spec": {
    "driver": "doubao-realtime",
    "doubao_realtime": {
      "realtime_model": "e2e-realtime",
      "realtime": {
        "session": {
          "auth_mode": "v2",
          "bot_name": "豆包",
          "model": "1.2.1.1",
          "resource_id": "volc.speech.dialog",
          "system_role": "你是一个简短、自然的中文语音聊天助手。",
          "vad_window_ms": 200
        },
        "output": {
          "speaker": "zh_female_vv_jupiter_bigtts"
        }
      }
    }
  }
}
