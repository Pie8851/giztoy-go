{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "Workflow",
  "metadata": {
    "name": "e2e-ast-translate-zh-jp",
    "description": "Workspace e2e AST Chinese to Japanese speech translation workflow"
  },
  "spec": {
    "driver": "ast-translate",
    "ast_translate": {
      "translation_model": "e2e-ast-translate",
      "auth_mode": "v2",
      "mode": "s2s",
      "resource_id": "volc.service_type.10053",
      "denoise": false
    }
  }
}
