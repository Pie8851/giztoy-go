{
  "agent": "ast-translate",
  "models": {
    "llm": "e2e-doubao-2-lite-chat",
    "tts": "e2e-tts",
    "asr": "e2e-asr",
    "translation": "e2e-ast-translate"
  },
  "workflow": {
    "name": "e2e-ast-translate-tts",
    "description": "Workspace e2e AST text translation with external GizClaw TTS voice",
    "translation_model": "e2e-ast-translate",
    "parameters": {
      "input": "push-to-talk",
      "lang_pair": "auto"
    },
    "ast_translate": {
      "auth_mode": "v2",
      "mode": "s2t",
      "voice": {
        "tts_voice": "volc-tenant:e2e-volc-tenant:zh_female_vv_mars_bigtts"
      },
      "resource_id": "volc.service_type.10053",
      "denoise": false
    }
  },
  "voice": "volc-tenant:e2e-volc-tenant:zh_female_vv_mars_bigtts",
  "rounds": 3,
  "timeout": "300s",
  "persona": "You are a concise Chinese voice translation test user. Keep every utterance short, clear, and speech friendly."
}
