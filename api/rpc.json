{
  "openapi": "3.0.3",
  "info": {
    "title": "RPC API",
    "description": "Schemas used by the internal framed RPC protocol.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "RPCRequest": {
        "type": "object",
        "required": [
          "v",
          "id",
          "method"
        ],
        "properties": {
          "v": {
            "$ref": "#/components/schemas/RPCVersion"
          },
          "id": {
            "type": "string"
          },
          "method": {
            "$ref": "#/components/schemas/RPCMethod"
          },
          "params": {
            "oneOf": [
              {
                "$ref": "./rpc/peer.json#/components/schemas/PingRequest"
              },
              {
                "$ref": "./rpc/gear.json#/components/schemas/DeviceGetInfoRequest"
              },
              {
                "$ref": "./rpc/gear.json#/components/schemas/DeviceGetIdentifiersRequest"
              },
              {
                "$ref": "./rpc/public.json#/components/schemas/ServerGetInfoRequest"
              },
              {
                "$ref": "./rpc/gear.json#/components/schemas/PeerGetInfoRequest"
              },
              {
                "$ref": "./rpc/gear.json#/components/schemas/PeerPutInfoRequest"
              },
              {
                "$ref": "./rpc/gear.json#/components/schemas/PeerGetRuntimeRequest"
              }
            ]
          }
        }
      },
      "RPCResponse": {
        "type": "object",
        "required": [
          "v",
          "id"
        ],
        "properties": {
          "v": {
            "$ref": "#/components/schemas/RPCVersion"
          },
          "id": {
            "type": "string"
          },
          "result": {
            "oneOf": [
              {
                "$ref": "./rpc/peer.json#/components/schemas/PingResponse"
              },
              {
                "$ref": "./rpc/gear.json#/components/schemas/DeviceGetInfoResponse"
              },
              {
                "$ref": "./rpc/gear.json#/components/schemas/DeviceGetIdentifiersResponse"
              },
              {
                "$ref": "./rpc/public.json#/components/schemas/ServerGetInfoResponse"
              },
              {
                "$ref": "./rpc/gear.json#/components/schemas/PeerGetInfoResponse"
              },
              {
                "$ref": "./rpc/gear.json#/components/schemas/PeerPutInfoResponse"
              },
              {
                "$ref": "./rpc/gear.json#/components/schemas/PeerGetRuntimeResponse"
              }
            ]
          },
          "error": {
            "$ref": "#/components/schemas/RPCError"
          }
        }
      },
      "RPCMethod": {
        "type": "string",
        "enum": [
          "peer.ping",
          "device.info.get",
          "device.identifiers.get",
          "peer.info.get",
          "peer.info.put",
          "peer.runtime.get",
          "server.info.get"
        ]
      },
      "RPCVersion": {
        "type": "integer",
        "enum": [
          1
        ],
        "x-enum-varnames": [
          "V1"
        ]
      },
      "RPCErrorCode": {
        "type": "integer",
        "enum": [
          -32600,
          -32601,
          -32602,
          -32603,
          400,
          404,
          409
        ],
        "x-enum-varnames": [
          "InvalidRequest",
          "MethodNotFound",
          "InvalidParams",
          "InternalError",
          "BadRequest",
          "NotFound",
          "Conflict"
        ]
      },
      "RPCError": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "$ref": "#/components/schemas/RPCErrorCode"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
