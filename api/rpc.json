{
  "openapi": "3.0.3",
  "info": {
    "title": "RPC API",
    "description": "Schemas used by the internal framed RPC protocol.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "RPCRequest": {
        "type": "object",
        "required": [
          "v",
          "id",
          "method"
        ],
        "properties": {
          "v": {
            "$ref": "#/components/schemas/RPCVersion"
          },
          "id": {
            "type": "string"
          },
          "method": {
            "$ref": "#/components/schemas/RPCMethod"
          },
          "params": {
            "oneOf": [
              {
                "$ref": "./rpc/ping.json#/components/schemas/PingRequest"
              },
              {
                "$ref": "./rpc/server_info.json#/components/schemas/ServerGetInfoRequest"
              },
              {
                "$ref": "./rpc/gear_config.json#/components/schemas/GearGetConfigRequest"
              },
              {
                "$ref": "./rpc/gear_info.json#/components/schemas/GearGetInfoRequest"
              },
              {
                "$ref": "./rpc/gear_info.json#/components/schemas/GearPutInfoRequest"
              },
              {
                "$ref": "./rpc/gear_ota.json#/components/schemas/GearGetOTARequest"
              },
              {
                "$ref": "./rpc/gear_registration.json#/components/schemas/GearGetRegistrationRequest"
              },
              {
                "$ref": "./rpc/gear_registration.json#/components/schemas/GearRegisterRequest"
              },
              {
                "$ref": "./rpc/gear_runtime.json#/components/schemas/GearGetRuntimeRequest"
              }
            ]
          }
        }
      },
      "RPCResponse": {
        "type": "object",
        "required": [
          "v",
          "id"
        ],
        "properties": {
          "v": {
            "$ref": "#/components/schemas/RPCVersion"
          },
          "id": {
            "type": "string"
          },
          "result": {
            "oneOf": [
              {
                "$ref": "./rpc/ping.json#/components/schemas/PingResponse"
              },
              {
                "$ref": "./rpc/server_info.json#/components/schemas/ServerGetInfoResponse"
              },
              {
                "$ref": "./rpc/gear_config.json#/components/schemas/GearGetConfigResponse"
              },
              {
                "$ref": "./rpc/gear_info.json#/components/schemas/GearGetInfoResponse"
              },
              {
                "$ref": "./rpc/gear_info.json#/components/schemas/GearPutInfoResponse"
              },
              {
                "$ref": "./rpc/gear_ota.json#/components/schemas/GearGetOTAResponse"
              },
              {
                "$ref": "./rpc/gear_registration.json#/components/schemas/GearGetRegistrationResponse"
              },
              {
                "$ref": "./rpc/gear_registration.json#/components/schemas/GearRegisterResponse"
              },
              {
                "$ref": "./rpc/gear_runtime.json#/components/schemas/GearGetRuntimeResponse"
              }
            ]
          },
          "error": {
            "$ref": "#/components/schemas/RPCError"
          }
        }
      },
      "RPCMethod": {
        "type": "string",
        "enum": [
          "peer.ping",
          "server.info.get",
          "gear.config.get",
          "gear.info.get",
          "gear.info.put",
          "gear.ota.get",
          "gear.registration.get",
          "gear.registration.register",
          "gear.runtime.get"
        ]
      },
      "RPCVersion": {
        "type": "integer",
        "enum": [
          1
        ],
        "x-enum-varnames": [
          "V1"
        ]
      },
      "RPCErrorCode": {
        "type": "integer",
        "enum": [
          -32600,
          -32601,
          -32602,
          -32603,
          400,
          404,
          409
        ],
        "x-enum-varnames": [
          "InvalidRequest",
          "MethodNotFound",
          "InvalidParams",
          "InternalError",
          "BadRequest",
          "NotFound",
          "Conflict"
        ]
      },
      "RPCError": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "$ref": "#/components/schemas/RPCErrorCode"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
