          {"name": "step_ms", "in": "query", "required": false, "schema": {"type": "integer", "format": "int64"}},
          {"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "format": "int32"}},
          {"name": "order", "in": "query", "required": false, "schema": {"$ref": "./shared.json#/components/schemas/PeerTelemetryOrder"}}
