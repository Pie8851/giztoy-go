{
  "openapi": "3.0.3",
  "info": {
    "title": "Peer HTTP API",
    "description": "Peer HTTP endpoints.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "PeerHTTP",
      "description": "Peer HTTP operations"
    },
    {
      "name": "Auth",
      "description": "Peer HTTP authentication"
    },
    {
      "name": "SideControl",
      "description": "Authorized side-control operations"
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "operationId": "login",
        "summary": "Exchange a device assertion for a bearer session",
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "X-Public-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResult"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "description": "Invalid assertion",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./shared.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/me/side-control/device-tokens": {
      "post": {
        "operationId": "createSideControlDeviceToken",
        "summary": "Create a single-use side-control device token",
        "tags": ["SideControl"],
        "security": [{"BearerAuth": []}],
        "responses": {
          "201": {
            "description": "Created device token",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SideControlDeviceToken"}}}
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "403": {"$ref": "#/components/responses/Forbidden"},
          "500": {"$ref": "#/components/responses/InternalError"}
        }
      }
    },
    "/me/side-control/device-tokens/{tokenId}": {
      "delete": {
        "operationId": "revokeSideControlDeviceToken",
        "summary": "Revoke an unconsumed side-control device token",
        "tags": ["SideControl"],
        "security": [{"BearerAuth": []}],
        "parameters": [{
          "name": "tokenId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "minLength": 22,
            "maxLength": 22,
            "pattern": "^[A-Za-z0-9_-]{22}$"
          }
        }],
        "responses": {
          "204": {"description": "Device token revoked"},
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "403": {"$ref": "#/components/responses/Forbidden"},
          "404": {"$ref": "#/components/responses/NotFound"},
          "500": {"$ref": "#/components/responses/InternalError"}
        }
      }
    },
    "/me/side-control/sessions": {
      "get": {
        "operationId": "listSideControlSessions",
        "summary": "List active side-control sessions for the caller device",
        "tags": ["SideControl"],
        "security": [{"BearerAuth": []}],
        "responses": {
          "200": {
            "description": "Active side-control sessions",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SideControlSessionList"}}}
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "403": {"$ref": "#/components/responses/Forbidden"},
          "500": {"$ref": "#/components/responses/InternalError"}
        }
      }
    },
    "/me/side-control/sessions/{sessionId}": {
      "delete": {
