{
  "openapi": "3.0.3",
  "info": {
    "title": "GizClaw Resource Types",
    "description": "Declarative resource envelope schemas used by admin apply.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "ResourceAPIVersion": {
        "type": "string",
        "description": "API version for declarative GizClaw resources.",
        "enum": [
          "gizclaw.admin/v1alpha1"
        ]
      },
      "ResourceKind": {
        "type": "string",
        "description": "Declarative GizClaw resource kind.",
        "enum": [
          "Credential",
          "Firmware",
          "Contact",
          "Friend",
          "FriendGroup",
          "FriendGroupInviteToken",
          "FriendGroupMember",
          "Model",
          "DashScopeTenant",
          "DeepSeekTenant",
          "GeminiTenant",
          "MiniMaxTenant",
          "OpenAITenant",
          "VolcTenant",
          "Voice",
          "Tool",
          "Workflow",
          "Workspace",
          "PetDef",
          "BadgeDef",
          "GameDef",
          "RuntimeProfile",
          "RegistrationToken",
          "ResourceList"
        ]
      },
      "ResourceMetadata": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Resource name. Kind-specific rules apply. User-defined custom IDs use 8-48 lowercase ASCII characters, start with [a-z], end with [a-z0-9], and contain only [a-z0-9._-]."
          },
          "annotations": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "owner_public_key": {
            "type": "string",
            "description": "Immutable owner Public Key for Client-created resources. Admin-owned resources omit this field."
          }
        }
      },
      "Resource": {
        "oneOf": [
          {
            "$ref": "./credential.json#/components/schemas/CredentialResource"
          },
          {
            "$ref": "./firmware.json#/components/schemas/FirmwareResource"
          },
          {
            "$ref": "./contact.json#/components/schemas/ContactResource"
          },
          {
            "$ref": "./friend.json#/components/schemas/FriendResource"
          },
          {
            "$ref": "./friend_group.json#/components/schemas/FriendGroupResource"
          },
          {
            "$ref": "./friend_group_invite_token.json#/components/schemas/FriendGroupInviteTokenResource"
          },
          {
            "$ref": "./friend_group_member.json#/components/schemas/FriendGroupMemberResource"
          },
          {
            "$ref": "./model.json#/components/schemas/ModelResource"
          },
          {
            "$ref": "./dashscope_tenant.json#/components/schemas/DashScopeTenantResource"
          },
          {
            "$ref": "./deepseek_tenant.json#/components/schemas/DeepSeekTenantResource"
          },
          {
            "$ref": "./gemini_tenant.json#/components/schemas/GeminiTenantResource"
          },
          {
            "$ref": "./minimax_tenant.json#/components/schemas/MiniMaxTenantResource"
          },
          {
            "$ref": "./openai_tenant.json#/components/schemas/OpenAITenantResource"
          },
          {
            "$ref": "./volc_tenant.json#/components/schemas/VolcTenantResource"
          },
          {
            "$ref": "./voice.json#/components/schemas/VoiceResource"
          },
          {
            "$ref": "./tool.json#/components/schemas/ToolResource"
          },
          {
            "$ref": "./workflow.json#/components/schemas/WorkflowResource"
          },
          {
            "$ref": "./workspace.json#/components/schemas/WorkspaceResource"
          },
          {
            "$ref": "./pet_def.json#/components/schemas/PetDefResource"
          },
          {
            "$ref": "./badge_def.json#/components/schemas/BadgeDefResource"
          },
          {
            "$ref": "./game_def.json#/components/schemas/GameDefResource"
          },
          {
            "$ref": "./runtime_profile.json#/components/schemas/RuntimeProfileResource"
          },
          {
            "$ref": "./registration_token.json#/components/schemas/RegistrationTokenResource"
          },
          {
            "$ref": "./resource_list.json#/components/schemas/ResourceListResource"
          }
        ],
        "discriminator": {
          "propertyName": "kind",
          "mapping": {
            "Credential": "./credential.json#/components/schemas/CredentialResource",
            "Firmware": "./firmware.json#/components/schemas/FirmwareResource",
            "Contact": "./contact.json#/components/schemas/ContactResource",
            "Friend": "./friend.json#/components/schemas/FriendResource",
            "FriendGroup": "./friend_group.json#/components/schemas/FriendGroupResource",
            "FriendGroupInviteToken": "./friend_group_invite_token.json#/components/schemas/FriendGroupInviteTokenResource",
            "FriendGroupMember": "./friend_group_member.json#/components/schemas/FriendGroupMemberResource",
            "DashScopeTenant": "./dashscope_tenant.json#/components/schemas/DashScopeTenantResource",
            "DeepSeekTenant": "./deepseek_tenant.json#/components/schemas/DeepSeekTenantResource",
            "GeminiTenant": "./gemini_tenant.json#/components/schemas/GeminiTenantResource",
            "Model": "./model.json#/components/schemas/ModelResource",
            "MiniMaxTenant": "./minimax_tenant.json#/components/schemas/MiniMaxTenantResource",
            "OpenAITenant": "./openai_tenant.json#/components/schemas/OpenAITenantResource",
            "VolcTenant": "./volc_tenant.json#/components/schemas/VolcTenantResource",
            "Voice": "./voice.json#/components/schemas/VoiceResource",
            "Tool": "./tool.json#/components/schemas/ToolResource",
            "Workflow": "./workflow.json#/components/schemas/WorkflowResource",
            "Workspace": "./workspace.json#/components/schemas/WorkspaceResource",
            "ResourceList": "./resource_list.json#/components/schemas/ResourceListResource",
            "PetDef": "./pet_def.json#/components/schemas/PetDefResource",
            "BadgeDef": "./badge_def.json#/components/schemas/BadgeDefResource",
            "GameDef": "./game_def.json#/components/schemas/GameDefResource",
            "RuntimeProfile": "./runtime_profile.json#/components/schemas/RuntimeProfileResource",
            "RegistrationToken": "./registration_token.json#/components/schemas/RegistrationTokenResource"
          }
        }
      },
      "ApplyAction": {
        "type": "string",
        "description": "Result of applying the resource.",
        "enum": [
          "created",
          "updated",
          "unchanged",
          "applied"
        ]
      },
      "ApplyResult": {
        "type": "object",
        "required": [
          "apiVersion",
          "kind",
          "name",
          "action"
        ],
        "properties": {
          "apiVersion": {
            "$ref": "#/components/schemas/ResourceAPIVersion"
          },
          "kind": {
            "$ref": "#/components/schemas/ResourceKind"
          },
          "name": {
            "type": "string"
          },
          "action": {
            "$ref": "#/components/schemas/ApplyAction"
          },
          "message": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "description": "Nested apply results for ResourceList resources.",
            "items": {
              "$ref": "#/components/schemas/ApplyResult"
            }
          }
        }
      }
    }
  }
}
