{
  "openapi": "3.0.3",
  "info": {
    "title": "Workspace Type",
    "description": "Workspace schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "Workspace": {
        "type": "object",
        "required": [
          "name",
          "workflow_name",
          "system",
          "created_at",
          "last_active_at",
          "updated_at"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "owner_public_key": {
            "type": "string",
            "readOnly": true,
            "description": "Immutable owner Peer public key. Domain-created system Workspaces always persist it."
          },
          "labels": {
            "type": "object",
            "maxProperties": 32,
            "description": "Stored Workspace labels used by Admin and internal exact-match filtering. Peer RPC does not project this map.",
            "additionalProperties": {
              "type": "string"
            }
          },
          "workflow_name": {
            "type": "string"
          },
          "system": {
            "type": "boolean",
            "readOnly": true,
            "description": "Whether the Workspace lifecycle is owned by another domain service. System Workspaces cannot be deleted through generic Workspace operations."
          },
          "parameters": {
            "$ref": "./workspace_parameters.json#/components/schemas/WorkspaceParameters"
          },
          "toolkit": {
            "$ref": "./toolkit_policy.json#/components/schemas/ToolkitPolicy"
          },
          "icon": {
            "$ref": "./icon.json#/components/schemas/Icon"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_active_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last user-visible workspace conversation or history activity time. Configuration-only updates must not modify this field."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
