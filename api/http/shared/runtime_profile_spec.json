{
  "openapi": "3.0.3",
  "info": {
    "title": "RuntimeProfile Spec Schema",
    "description": "RuntimeProfile alias bindings and gameplay policy.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "RuntimeProfileI18nText": {
        "type": "object",
        "required": ["display_name"],
        "additionalProperties": false,
        "properties": {
          "display_name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      },
      "RuntimeProfileBinding": {
        "type": "object",
        "required": ["resource_id", "i18n"],
        "additionalProperties": false,
        "properties": {
          "resource_id": { "type": "string", "minLength": 1 },
          "i18n": {
            "type": "object",
            "required": ["en", "zh-CN"],
            "additionalProperties": {
              "$ref": "#/components/schemas/RuntimeProfileI18nText"
            }
          }
        }
      },
      "RuntimeProfileWorkflowCollections": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/components/schemas/RuntimeProfileBinding"
          }
        }
      },
      "RuntimeProfileSystemWorkflows": {
        "type": "object",
        "required": ["friend_chatroom", "group_chatroom", "pet"],
        "additionalProperties": false,
        "properties": {
          "friend_chatroom": {
            "type": "string",
            "minLength": 1,
            "description": "Persisted Workflow resource ID for direct friend chat Workspaces."
          },
          "group_chatroom": {
            "type": "string",
            "minLength": 1,
            "description": "Persisted Workflow resource ID for friend-group chat Workspaces."
          },
          "pet": {
            "type": "string",
            "minLength": 1,
            "description": "Persisted Workflow resource ID for adopted Pet Workspaces."
          }
        }
      },
      "RuntimeProfileWorkflows": {
        "type": "object",
        "required": ["system", "collections"],
        "additionalProperties": false,
        "properties": {
          "system": {
            "$ref": "#/components/schemas/RuntimeProfileSystemWorkflows"
          },
          "collections": {
            "$ref": "#/components/schemas/RuntimeProfileWorkflowCollections"
          }
        }
      },
      "RuntimeProfileResources": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "models": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/RuntimeProfileBinding" }
          },
          "voices": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/RuntimeProfileBinding" }
          },
          "tools": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/RuntimeProfileBinding" }
          },
          "pet_defs": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/RuntimeProfileBinding" }
          },
          "game_defs": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/RuntimeProfileBinding" }
          },
          "badge_defs": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/RuntimeProfileBinding" }
          }
        }
      },
      "RuntimeProfilePointsSpec": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "initial_balance": { "type": "integer", "format": "int64", "default": 0 }
        }
      },
      "RuntimeProfilePetPoolEntry": {
        "type": "object",
        "required": ["pet_def", "weight"],
        "additionalProperties": false,
        "properties": {
          "pet_def": { "type": "string" },
          "weight": { "type": "integer", "format": "int64", "minimum": 1 },
          "rarity": { "type": "string" },
          "adoption_cost": { "type": "integer", "format": "int64", "default": 0 }
        }
      },
      "RuntimeProfileAdoptionSpec": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "pool": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/RuntimeProfilePetPoolEntry" }
          }
        }
      },
      "RuntimeProfileCareDecaySpec": {
        "type": "object",
        "required": ["health", "satiety", "hygiene", "mood"],
        "additionalProperties": false,
        "properties": {
          "health": { "type": "number", "format": "double", "minimum": 0 },
          "satiety": { "type": "number", "format": "double", "minimum": 0 },
          "hygiene": { "type": "number", "format": "double", "minimum": 0 },
          "mood": { "type": "number", "format": "double", "minimum": 0 }
        }
      },
      "RuntimeProfileLifeWeightsSpec": {
        "type": "object",
        "required": ["health", "satiety", "hygiene", "mood"],
        "additionalProperties": false,
        "properties": {
          "health": { "type": "number", "format": "double", "minimum": 0, "maximum": 1 },
          "satiety": { "type": "number", "format": "double", "minimum": 0, "maximum": 1 },
          "hygiene": { "type": "number", "format": "double", "minimum": 0, "maximum": 1 },
          "mood": { "type": "number", "format": "double", "minimum": 0, "maximum": 1 }
        }
      },
      "RuntimeProfileLifeDecaySpec": {
        "type": "object",
        "required": ["contributing_weights", "max_loss_per_hour", "exponent"],
        "additionalProperties": false,
        "properties": {
          "contributing_weights": { "$ref": "#/components/schemas/RuntimeProfileLifeWeightsSpec" },
          "max_loss_per_hour": { "type": "number", "format": "double", "minimum": 0 },
          "exponent": { "type": "number", "format": "double", "exclusiveMinimum": true, "minimum": 1 }
        }
      },
      "RuntimeProfilePetTimeSpec": {
        "type": "object",
        "required": ["care_decay_per_hour", "energy_recovery_per_hour", "life_decay"],
        "additionalProperties": false,
        "properties": {
          "care_decay_per_hour": { "$ref": "#/components/schemas/RuntimeProfileCareDecaySpec" },
          "energy_recovery_per_hour": { "type": "number", "format": "double", "minimum": 0 },
          "life_decay": { "$ref": "#/components/schemas/RuntimeProfileLifeDecaySpec" }
        }
      },
      "RuntimeProfileLevelingSpec": {
        "type": "object",
        "required": ["base_exp", "log_scale"],
        "additionalProperties": false,
        "properties": {
          "base_exp": { "type": "integer", "format": "int64", "minimum": 1 },
          "log_scale": { "type": "number", "format": "double", "minimum": 0, "maximum": 100 }
        }
      },
      "RuntimeProfilePetExperienceSpec": {
        "type": "object",
        "required": ["energy_per_pet_exp", "leveling"],
        "additionalProperties": false,
        "properties": {
          "energy_per_pet_exp": { "type": "integer", "format": "int64", "minimum": 1 },
          "leveling": { "$ref": "#/components/schemas/RuntimeProfileLevelingSpec" }
        }
      },
      "RuntimeProfilePetActionSpec": {
        "type": "object",
        "required": ["energy_cost", "stat_delta"],
        "additionalProperties": false,
        "properties": {
          "energy_cost": { "type": "integer", "format": "int64", "minimum": 1, "maximum": 100 },
          "stat_delta": { "type": "number", "format": "double", "exclusiveMinimum": true, "minimum": 0, "maximum": 100 }
        }
      },
      "RuntimeProfilePetActionsSpec": {
        "type": "object",
        "required": ["feed", "bathe", "play", "heal"],
        "additionalProperties": false,
        "properties": {
          "feed": { "$ref": "#/components/schemas/RuntimeProfilePetActionSpec" },
          "bathe": { "$ref": "#/components/schemas/RuntimeProfilePetActionSpec" },
          "play": { "$ref": "#/components/schemas/RuntimeProfilePetActionSpec" },
          "heal": { "$ref": "#/components/schemas/RuntimeProfilePetActionSpec" }
        }
      },
      "RuntimeProfileGameRewardSpec": {
        "type": "object",
        "required": ["model", "pet_exp_max", "badge_exp_max_per_badge", "prompt"],
        "additionalProperties": false,
        "properties": {
          "model": { "type": "string", "minLength": 1 },
          "pet_exp_max": { "type": "integer", "format": "int64", "minimum": 0 },
          "badge_exp_max_per_badge": { "type": "integer", "format": "int64", "minimum": 0 },
          "prompt": { "type": "string", "minLength": 1 }
        }
      },
      "RuntimeProfileGameSpec": {
        "type": "object",
        "required": ["energy_cost", "points_cost", "reward"],
        "additionalProperties": false,
        "properties": {
          "energy_cost": { "type": "integer", "format": "int64", "minimum": 1, "maximum": 100 },
          "points_cost": { "type": "integer", "format": "int64", "minimum": 0 },
          "reward": { "$ref": "#/components/schemas/RuntimeProfileGameRewardSpec" }
        }
      },
      "RuntimeProfilePetGameplaySpec": {
        "type": "object",
        "required": ["time", "experience", "actions", "games"],
        "additionalProperties": false,
        "properties": {
          "time": { "$ref": "#/components/schemas/RuntimeProfilePetTimeSpec" },
          "experience": { "$ref": "#/components/schemas/RuntimeProfilePetExperienceSpec" },
          "actions": { "$ref": "#/components/schemas/RuntimeProfilePetActionsSpec" },
          "games": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/RuntimeProfileGameSpec" }
          }
        }
      },
      "RuntimeProfileGameplaySpec": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "points": { "$ref": "#/components/schemas/RuntimeProfilePointsSpec" },
          "adoption": { "$ref": "#/components/schemas/RuntimeProfileAdoptionSpec" },
          "pet": { "$ref": "#/components/schemas/RuntimeProfilePetGameplaySpec" }
        }
      },
      "RuntimeProfileSpec": {
        "type": "object",
        "required": ["workflows", "resources"],
        "additionalProperties": false,
        "properties": {
          "workflows": { "$ref": "#/components/schemas/RuntimeProfileWorkflows" },
          "resources": { "$ref": "#/components/schemas/RuntimeProfileResources" },
          "gameplay": { "$ref": "#/components/schemas/RuntimeProfileGameplaySpec" }
        }
      }
    }
  }
}
