{
  "openapi": "3.0.3",
  "info": {
    "title": "Workspace Parameters Type",
    "description": "WorkspaceParameters schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "WorkspaceParameters": {
        "description": "Agent-specific workspace parameters. The shape is selected by agent_type.",
        "oneOf": [
          {
            "$ref": "#/components/schemas/FlowcraftWorkspaceParameters"
          },
          {
            "$ref": "#/components/schemas/DoubaoRealtimeWorkspaceParameters"
          },
          {
            "$ref": "#/components/schemas/ASTTranslateWorkspaceParameters"
          },
          {
            "$ref": "#/components/schemas/ChatRoomWorkspaceParameters"
          }
        ],
        "discriminator": {
          "propertyName": "agent_type",
          "mapping": {
            "flowcraft": "#/components/schemas/FlowcraftWorkspaceParameters",
            "doubao-realtime": "#/components/schemas/DoubaoRealtimeWorkspaceParameters",
            "ast-translate": "#/components/schemas/ASTTranslateWorkspaceParameters",
            "chatroom": "#/components/schemas/ChatRoomWorkspaceParameters"
          }
        }
      },
      "WorkspaceInputMode": {
        "type": "string",
        "enum": [
          "push-to-talk",
          "realtime"
        ]
      },
      "FlowcraftConversationParameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "initiative": {
            "type": "string",
            "enum": [
              "peer",
              "agent"
            ],
            "description": "Who starts the conversation when the workspace runtime opens."
          },
          "agent_initiative_policy": {
            "type": "string",
            "enum": [
              "once_when_empty",
              "on_reload"
            ],
            "description": "When agent initiative is allowed."
          }
        }
      },
      "FlowcraftWorkspaceParameters": {
        "type": "object",
        "required": [
          "agent_type"
        ],
        "additionalProperties": false,
        "properties": {
          "agent_type": {
            "type": "string",
            "enum": [
              "flowcraft"
            ]
          },
          "input": {
            "$ref": "#/components/schemas/WorkspaceInputMode"
          },
          "conversation": {
            "$ref": "#/components/schemas/FlowcraftConversationParameters"
          },
          "e2e": {
            "type": "boolean",
            "description": "Marks seed resources used by the local e2e harness."
          }
        },
        "example": {
          "agent_type": "flowcraft",
          "input": "push-to-talk",
          "conversation": {
            "initiative": "agent",
            "agent_initiative_policy": "once_when_empty"
          }
        }
      },
      "DoubaoRealtimeWorkspaceParameters": {
        "type": "object",
        "required": [
          "agent_type"
        ],
        "additionalProperties": false,
        "properties": {
          "agent_type": {
            "type": "string",
            "enum": [
              "doubao-realtime"
            ]
          },
          "model": {
            "type": "string",
            "description": "RuntimeProfile Model alias. Defaults to Workflow.spec.doubao_realtime.model."
          },
          "instructions": {
            "type": "string"
          },
          "input": {
            "$ref": "#/components/schemas/WorkspaceInputMode"
          },
          "audio": {
            "$ref": "./workflows/doubao_realtime.json#/components/schemas/DoubaoRealtimeAudio"
          },
          "tools": {
            "type": "array",
            "items": {
              "$ref": "./workflows/doubao_realtime.json#/components/schemas/DoubaoRealtimeFunctionTool"
            }
          },
          "extension": {
            "$ref": "./workflows/doubao_realtime.json#/components/schemas/DoubaoRealtimeExtension"
          },
          "e2e": {
            "type": "boolean",
            "description": "Marks seed resources used by the local e2e harness."
          }
        },
        "example": {
          "agent_type": "doubao-realtime",
          "model": "e2e-realtime",
          "input": "push-to-talk",
          "audio": {
            "input": {
              "format": {
                "type": "speech_opus",
                "rate": 16000
              }
            },
            "output": {
              "format": {
                "type": "ogg_opus",
                "rate": 24000
              },
              "voice": "zh_female_vv_jupiter_bigtts"
            }
          }
        }
      },
      "ASTTranslateWorkspaceParameters": {
        "type": "object",
        "required": [
          "agent_type"
        ],
        "additionalProperties": false,
        "properties": {
          "agent_type": {
            "type": "string",
            "enum": [
              "ast-translate"
            ]
          },
          "translation_model": {
            "type": "string"
          },
          "input": {
            "$ref": "#/components/schemas/WorkspaceInputMode"
          },
          "mode": {
            "$ref": "./workflows/ast_translate.json#/components/schemas/ASTTranslateMode"
          },
          "lang_pair": {
            "type": "string",
            "description": "AST language pair, for example zh/en or en/zh. Use auto for automatic Chinese/English mode."
          },
          "voice": {
            "$ref": "#/components/schemas/ASTTranslateVoiceParameters"
          },
          "enable_source_language_detect": {
            "type": "boolean"
          },
          "denoise": {
            "type": "boolean"
          },
          "e2e": {
            "type": "boolean",
            "description": "Marks seed resources used by the local e2e harness."
          }
        },
        "example": {
          "agent_type": "ast-translate",
          "translation_model": "e2e-ast-translate",
          "input": "push-to-talk",
          "mode": "s2t",
          "lang_pair": "auto"
        }
      },
      "ASTTranslateVoiceParameters": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/ASTTranslateInternalSpeakerParameters"
          },
          {
            "$ref": "#/components/schemas/ASTTranslateExternalVoiceParameters"
          }
        ]
      },
      "ASTTranslateInternalSpeakerParameters": {
        "type": "object",
        "required": [
          "speaker_id"
        ],
        "additionalProperties": false,
        "properties": {
          "speaker_id": {
            "type": "string",
            "description": "AST s2s built-in or custom speaker id."
          },
          "is_custom_speaker": {
            "type": "boolean"
          },
          "tts_resource_id": {
            "type": "string"
          },
          "speech_rate": {
            "type": "integer"
          }
        }
      },
      "ASTTranslateExternalVoiceParameters": {
        "type": "object",
        "required": [
          "tts_voice"
        ],
        "additionalProperties": false,
        "properties": {
          "tts_voice": {
            "type": "string",
            "description": "RuntimeProfile Voice alias used by the external TTS path."
          }
        }
      },
      "ChatRoomMode": {
        "type": "string",
        "enum": [
          "direct",
          "group"
        ]
      },
      "ChatRoomWorkspaceHistoryParameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "ttl": {
            "type": "string",
            "description": "Workspace-level retention override for chat history entries and their assets."
          }
        }
      },
      "ChatRoomWorkspaceTranscriptParameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Whether gear audio should be transcribed and written as text in workspace history."
          },
          "asr_model": {
            "type": "string",
            "description": "Workspace-level ASR model override for gear audio transcription."
          }
        }
      },
      "ChatRoomWorkspaceParameters": {
        "type": "object",
        "required": [
          "agent_type"
        ],
        "additionalProperties": false,
        "properties": {
          "agent_type": {
            "type": "string",
            "enum": [
              "chatroom"
            ]
          },
          "input": {
            "$ref": "#/components/schemas/WorkspaceInputMode"
          },
          "mode": {
            "$ref": "#/components/schemas/ChatRoomMode"
          },
          "history": {
            "$ref": "#/components/schemas/ChatRoomWorkspaceHistoryParameters"
          },
          "transcript": {
            "$ref": "#/components/schemas/ChatRoomWorkspaceTranscriptParameters"
          }
        },
        "example": {
          "agent_type": "chatroom",
          "input": "push-to-talk",
          "mode": "group"
        }
      }
    }
  }
}
