            "type": "boolean"
          },
          "last_seen_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_addr": {
            "type": "string"
          },
          "rx_bytes": {
            "type": "integer",
            "format": "uint64"
          },
          "tx_bytes": {
            "type": "integer",
            "format": "uint64"
          }
        }
      }
    }
  }
}
