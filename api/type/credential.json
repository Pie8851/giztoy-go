{
  "openapi": "3.0.3",
  "info": {
    "title": "Credential Type",
    "description": "Credential schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "Credential": {
        "type": "object",
        "required": [
          "name",
          "provider",
          "body",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "body": {
            "$ref": "./credential_body.json#/components/schemas/CredentialBody"
          },
          "description": {
            "type": "string",
            "example": "primary openai credential"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
