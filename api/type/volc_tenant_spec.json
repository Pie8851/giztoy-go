{
  "openapi": "3.0.3",
  "info": {
    "title": "Volc Tenant Spec Type",
    "description": "VolcTenantSpec schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "VolcTenantSpec": {
        "type": "object",
        "required": [
          "credential_name"
        ],
        "properties": {
          "credential_name": {
            "type": "string"
          },
          "region": {
            "type": "string",
            "example": "cn-beijing"
          },
          "endpoint": {
            "type": "string",
            "format": "uri",
            "example": "https://open.volcengineapi.com"
          },
          "resource_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "seed-tts-2.0"
            ]
          },
          "description": {
            "type": "string",
            "example": "primary Volcengine tenant for Doubao voices"
          }
        }
      }
    }
  }
}
