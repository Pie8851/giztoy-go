{
  "openapi": "3.0.3",
  "info": {
    "title": "Server Public API",
    "description": "Public server endpoints.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "Public",
      "description": "Public peer operations"
    },
    {
      "name": "Auth",
      "description": "Public HTTP authentication"
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "operationId": "login",
        "summary": "Exchange a device assertion for a bearer session",
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "X-Public-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResult"
                }
              }
            }
          },
          "401": {
            "description": "Invalid assertion",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/server-info": {
      "get": {
        "operationId": "getServerInfo",
        "summary": "Get server information",
        "tags": [
          "Public"
        ],
        "responses": {
          "200": {
            "description": "Server info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ServerInfo"
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginResult": {
        "type": "object",
        "required": [
          "access_token",
          "token_type",
          "expires_at"
        ],
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string",
            "enum": [
              "Bearer"
            ]
          },
          "expires_at": {
            "type": "integer",
            "format": "int64"
          }
        }
      }
    }
  }
}
