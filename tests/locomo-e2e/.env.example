# Copy to .env. This suite is manual, networked, potentially slow, and billable.
GIZCLAW_LOCOMO_E2E_TEST_REGEX=TestLoCoMoFlowcraftBM25SinglePass
GIZCLAW_LOCOMO_E2E_TEST_TIMEOUT=30m
GIZCLAW_LOCOMO_E2E_DATASET=tests/locomo-e2e/testdata/locomo10_smoke.jsonl
GIZCLAW_LOCOMO_E2E_REPORT_DIR=tests/locomo-e2e/reports
GIZCLAW_LOCOMO_E2E_TOP_K=10
GIZCLAW_LOCOMO_E2E_INGEST_TIMEOUT=10m
GIZCLAW_LOCOMO_E2E_QA_TIMEOUT=2m
GIZCLAW_LOCOMO_E2E_MIN_F1=0.05
GIZCLAW_LOCOMO_E2E_MIN_EVIDENCE_HIT_RATE=0.50

# Doubao through Volcengine Ark is the default extraction and answer model.
# MODEL_BASE_URL is only needed for a compatible proxy or non-default endpoint.
GIZCLAW_LOCOMO_E2E_MODEL_API_KEY=
GIZCLAW_LOCOMO_E2E_MODEL_BASE_URL=
GIZCLAW_LOCOMO_E2E_MODEL_REGION=cn-beijing
GIZCLAW_LOCOMO_E2E_EXTRACTION_MODEL=doubao-seed-2-0-lite-260215
GIZCLAW_LOCOMO_E2E_ANSWER_MODEL=doubao-seed-2-0-lite-260215
GIZCLAW_LOCOMO_E2E_RERANK_MODEL=

# Hybrid Flowcraft lanes additionally need an OpenAI-compatible embedding
# endpoint. Embedding credentials are deliberately separate from the LLM key.
GIZCLAW_LOCOMO_E2E_EMBEDDING_MODEL=
GIZCLAW_LOCOMO_E2E_EMBEDDING_API_KEY=
GIZCLAW_LOCOMO_E2E_EMBEDDING_BASE_URL=

# Mem0 Platform default project/deployment lane.
GIZCLAW_LOCOMO_E2E_MEM0_DEFAULT_ENDPOINT=https://api.mem0.ai
GIZCLAW_LOCOMO_E2E_MEM0_DEFAULT_API_KEY=
GIZCLAW_LOCOMO_E2E_MEM0_DEFAULT_FINGERPRINT=default-project

# A separately configured Mem0 project/deployment whose custom instructions
# are already installed remotely. The harness never mutates project config.
GIZCLAW_LOCOMO_E2E_MEM0_CUSTOM_INSTRUCTIONS_ENDPOINT=https://api.mem0.ai
GIZCLAW_LOCOMO_E2E_MEM0_CUSTOM_INSTRUCTIONS_API_KEY=
GIZCLAW_LOCOMO_E2E_MEM0_CUSTOM_INSTRUCTIONS_FINGERPRINT=

# Volcengine AgentKit Memory default lane. Supply either a resolved Mem0 API
# key or the control-plane project/key plus AK/SK used by the production adapter.
GIZCLAW_LOCOMO_E2E_VOLC_MEM0_ENDPOINT=
GIZCLAW_LOCOMO_E2E_VOLC_MEM0_API_KEY=
GIZCLAW_LOCOMO_E2E_VOLC_API_KEY_ID=
GIZCLAW_LOCOMO_E2E_VOLC_MEMORY_PROJECT_ID=
GIZCLAW_LOCOMO_E2E_VOLC_CONTROL_ENDPOINT=
GIZCLAW_LOCOMO_E2E_VOLC_REGION=cn-beijing
GIZCLAW_LOCOMO_E2E_VOLC_ACCESS_KEY_ID=
GIZCLAW_LOCOMO_E2E_VOLC_ACCESS_KEY_SECRET=
GIZCLAW_LOCOMO_E2E_VOLC_DEFAULT_FINGERPRINT=default-project
