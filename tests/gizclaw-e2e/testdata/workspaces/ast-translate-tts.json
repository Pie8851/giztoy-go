{
  "agent": "ast-translate",
  "models": {
    "llm": "doubao-lite-chat",
    "tts": "volc-bigtts",
    "asr": "volc-bigasr-sauc",
    "translation": "volc-ast-translate"
  },
  "workflow": {
    "name": "volc-ast-translate-tts",
    "description": "AST text translation with external GizClaw TTS voice",
    "translation_model": "volc-ast-translate",
    "parameters": {
      "input": "push-to-talk",
      "lang_pair": "auto"
    },
    "ast_translate": {
      "mode": "s2t",
      "voice": {
        "tts_voice": "volc-tenant:volc-main:zh_female_vv_mars_bigtts"
      },
      "resource_id": "volc.service_type.10053",
      "denoise": false
    }
  },
  "voice": "volc-tenant:volc-main:zh_female_vv_mars_bigtts",
  "rounds": 3,
  "timeout": "300s",
  "persona": "You are a concise Chinese voice translation test user. Keep every utterance short, clear, and speech friendly."
}
