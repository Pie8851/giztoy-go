ARG BASE_IMAGE=gizclaw-go:linux-amd64-cn-base
FROM ${BASE_IMAGE}

WORKDIR /src

COPY package.json package-lock.json ./
COPY apps/wails/frontend/package.json apps/wails/frontend/package.json
COPY sdk/js/package.json sdk/js/package.json
COPY sdk/js/gizclaw/package.json sdk/js/gizclaw/package.json
COPY js/packages/pixa/package.json js/packages/pixa/package.json

RUN npm ci

COPY . .
RUN find tests/gizclaw-e2e/docker -name '*.sh' -exec chmod +x {} +

ENTRYPOINT ["/src/tests/gizclaw-e2e/docker/entrypoint-desktop.sh"]
